DATABASE_URL="postgresql://postgres:postgres@localhost:5435/dnd-manager?schema=public"

# Session JWT signing key (must be >= 32 chars)
# Generate with: openssl rand -hex 32
AUTH_SECRET=""

# Email (Resend). When unset, verification codes are logged to the console in dev.
RESEND_API_KEY=""
EMAIL_FROM="D&D Manager <noreply@example.com>"

# Google OAuth (https://console.cloud.google.com -> Credentials -> OAuth 2.0 Client)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
