// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SITE_MANAGER
  TECHNICIAN
  VIEWER
}

enum AbilityName {
  STR
  DEX
  CON
  INT
  WIS
  CHA
}

enum SkillName {
  ACROBATICS
  ANIMAL_HANDLING
  ARCANA
  ATHLETICS
  DECEPTION
  HISTORY
  INSIGHT
  INTIMIDATION
  INVESTIGATION
  MEDICINE
  NATURE
  PERCEPTION
  PERFORMANCE
  PERSUASION
  RELIGION
  SLEIGHT_OF_HAND
  STEALTH
  SURVIVAL
}

enum SpellSchool {
  ABJURATION
  CONJURATION
  DIVINATION
  ENCHANTMENT
  EVOCATION
  ILLUSION
  NECROMANCY
  TRANSMUTATION
}

enum ItemType {
  WEAPON
  ARMOR
  SHIELD
  TOOL
  CONSUMABLE
  TREASURE
  MISC
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
}

enum NoteCategory {
  CAMPAIGN
  SESSION
  NPC
  LORE
  QUEST
  OTHER
}

enum CampaignRole {
  DM
  PLAYER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(VIEWER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions   Session[]
  auditLogs  AuditLog[]
  characters Character[]

  campaignsAsDm       Campaign[]           @relation("CampaignDm")
  campaignMemberships CampaignMembership[]
  handoutsAuthored    Handout[]            @relation("HandoutAuthor")
  handoutsReceived    HandoutRecipient[]
  sessionLogsAuthored SessionLog[]         @relation("SessionAuthor")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id     Int     @id @default(autoincrement())
  action String
  detail String?
  userId String
  user   User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Character {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  race           String
  subrace        String?
  characterClass String
  subclass       String?
  background     String
  alignment      String
  level          Int     @default(1)
  experience     Int     @default(0)
  inspiration    Boolean @default(false)
  portraitUrl    String?

  armorClass   Int @default(10)
  maxHp        Int @default(10)
  currentHp    Int @default(10)
  tempHp       Int @default(0)
  hitDiceTotal Int @default(1)
  hitDiceUsed  Int @default(0)
  hitDieType   Int @default(8)
  speed        Int @default(30)

  copper   Int @default(0)
  silver   Int @default(0)
  electrum Int @default(0)
  gold     Int @default(0)
  platinum Int @default(0)

  spellcastingAbility AbilityName?

  slot1Max  Int @default(0)
  slot1Used Int @default(0)
  slot2Max  Int @default(0)
  slot2Used Int @default(0)
  slot3Max  Int @default(0)
  slot3Used Int @default(0)
  slot4Max  Int @default(0)
  slot4Used Int @default(0)
  slot5Max  Int @default(0)
  slot5Used Int @default(0)
  slot6Max  Int @default(0)
  slot6Used Int @default(0)
  slot7Max  Int @default(0)
  slot7Used Int @default(0)
  slot8Max  Int @default(0)
  slot8Used Int @default(0)
  slot9Max  Int @default(0)
  slot9Used Int @default(0)

  personality String?
  ideals      String?
  bonds       String?
  flaws       String?
  backstory   String?
  appearance  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  abilities    AbilityScore[]
  savingThrows SavingThrow[]
  skills       SkillProficiency[]
  inventory    InventoryItem[]
  spells       Spell[]
  features     Feature[]
  conditions   Condition[]
  notes        Note[]

  campaignMemberships CampaignMembership[]

  @@index([userId])
}

model AbilityScore {
  id          String      @id @default(cuid())
  characterId String
  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  ability     AbilityName
  score       Int         @default(10)

  @@unique([characterId, ability])
}

model SavingThrow {
  id          String      @id @default(cuid())
  characterId String
  character   Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  ability     AbilityName
  proficient  Boolean     @default(false)

  @@unique([characterId, ability])
}

model SkillProficiency {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skill       SkillName
  proficient  Boolean   @default(false)
  expertise   Boolean   @default(false)

  @@unique([characterId, skill])
}

model InventoryItem {
  id          String     @id @default(cuid())
  characterId String
  character   Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  quantity    Int        @default(1)
  weight      Float      @default(0)
  equipped    Boolean    @default(false)
  attuned     Boolean    @default(false)
  type        ItemType   @default(MISC)
  rarity      ItemRarity @default(COMMON)
  description String?
  createdAt   DateTime   @default(now())

  @@index([characterId])
}

model Spell {
  id             String      @id @default(cuid())
  characterId    String
  character      Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name           String
  level          Int
  school         SpellSchool
  castingTime    String
  range          String
  components     String
  duration       String
  description    String
  prepared       Boolean     @default(false)
  alwaysPrepared Boolean     @default(false)

  @@index([characterId])
  @@index([characterId, level])
}

model Feature {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  source      String
  description String

  @@index([characterId])
}

model Condition {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name        String
  level       Int       @default(1)
  note        String?

  @@index([characterId])
}

model Note {
  id          String       @id @default(cuid())
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  title       String
  body        String
  category    NoteCategory @default(CAMPAIGN)
  pinned      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([characterId])
  @@index([characterId, pinned])
}

model Campaign {
  id         String   @id @default(cuid())
  name       String
  setting    String?
  premise    String?
  dmUserId   String
  dm         User     @relation("CampaignDm", fields: [dmUserId], references: [id], onDelete: Cascade)
  inviteCode String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships CampaignMembership[]
  handouts    Handout[]
  sessionLogs SessionLog[]

  @@index([dmUserId])
}

model CampaignMembership {
  id          String       @id @default(cuid())
  campaignId  String
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        CampaignRole @default(PLAYER)
  characterId String?
  character   Character?   @relation(fields: [characterId], references: [id], onDelete: SetNull)
  joinedAt    DateTime     @default(now())

  @@unique([campaignId, userId])
  @@index([userId])
  @@index([characterId])
}

model Handout {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  authorUserId String
  author       User     @relation("HandoutAuthor", fields: [authorUserId], references: [id])
  title        String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recipients HandoutRecipient[]

  @@index([campaignId])
}

model HandoutRecipient {
  id        String    @id @default(cuid())
  handoutId String
  handout   Handout   @relation(fields: [handoutId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinned    Boolean   @default(false)
  readAt    DateTime?

  @@unique([handoutId, userId])
  @@index([userId])
}

model SessionLog {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  authorUserId String
  author       User      @relation("SessionAuthor", fields: [authorUserId], references: [id])
  title        String
  body         String
  sessionDate  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([campaignId])
}

model CharacterPreset {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  archetype      String
  characterClass String
  subclass       String?
  race           String
  subrace        String?
  background     String
  alignment      String
  summary        String
  portraitUrl    String?
  payload        Json
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([characterClass])
  @@index([archetype])
}
